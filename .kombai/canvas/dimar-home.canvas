"text-[12px] text-white/45 tracking-wide\" data-kid=\"268\">© 2026 DIMAR STORE — Todos los derechos reservados</p>\n        <div class=\"flex items-center gap-2.5\" data-kid=\"269\">\n          <span class=\"px-3 py-1.5 border border-white/15 rounded-md text-[11px] font-semibold text-white/55 tracking-wide\" data-kid=\"270\">VISA</span>\n          <span class=\"px-3 py-1.5 border border-white/15 rounded-md text-[11px] font-semibold text-white/55 tracking-wide\" data-kid=\"271\">MASTERCARD</span>\n          <span class=\"px-3 py-1.5 border border-white/15 rounded-md text-[11px] font-semibold text-white/55 tracking-wide\" data-kid=\"272\">YAPE</span>\n          <span class=\"px-3 py-1.5 border border-white/15 rounded-md text-[11px] font-semibold text-white/55 tracking-wide\" data-kid=\"273\">MERCADOPAGO</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script type=\"module\" data-kid=\"274\">\n  import { animate, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n  // Fade-up-once reveals\n  inView(\".reveal\", (el) => {\n    animate(el, { opacity: [0, 1], y: [40, 0] }, { duration: 0.7, easing: \"ease-out\" });\n  }, { amount: 0.15 });\n\n  // Video showcase click-to-play\n  const wrap = document.getElementById(\"showcaseWrap\");\n  const vid = document.getElementById(\"showcaseVideo\");\n  const btn = document.getElementById(\"showcaseBtn\");\n  if (wrap && vid && btn) {\n    wrap.addEventListener(\"click\", () => {\n      if (vid.paused) { vid.play(); btn.style.opacity = \"0\"; btn.style.pointerEvents = \"none\"; }\n      else { vid.pause(); btn.style.opacity = \"1\"; btn.style.pointerEvents = \"auto\"; }\n    });\n    btn.style.transition = \"opacity .3s ease\";\n  }\n</script>",
