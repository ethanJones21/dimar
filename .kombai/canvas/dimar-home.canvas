      "html": "<link href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\" data-kid=\"0\">\n<style data-kid=\"1\">\n  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Public+Sans:wght@400;500;600;700&display=swap');\n  .font-serif-lora { font-family: 'Lora', Georgia, serif; }\n  .font-sans-pub { font-family: 'Public Sans', system-ui, sans-serif; }\n  .reveal { opacity: 0; transform: translateY(42px); }\n  .link-underline { background-image: linear-gradient(currentColor, currentColor); background-size: 0% 1px; background-repeat: no-repeat; background-position: 0 100%; transition: background-size .35s ease; }\n  .link-underline:hover { background-size: 100% 1px; }\n  .prod-img-wrap { transition: transform .4s ease, box-shadow .4s ease; }\n  .prod-img-wrap:hover { transform: translateY(-6px); box-shadow: 0 18px 44px rgba(75,54,33,.18); }\n  .cat-blob { transition: transform .5s ease; }\n  .cat-blob:hover { transform: scale(1.03) rotate(-1deg); }\n</style>\n\n<div class=\"font-sans-pub\" style=\"background-color:#F4F0EC; color:#4B3621;\" data-kid=\"2\">\n\n  \n  <header class=\"sticky top-0 z-50\" style=\"background-color:#F4F0ECF2; backdrop-filter:blur(8px);\" data-kid=\"3\">\n    <div class=\"max-w-[1240px] mx-auto px-8 h-20 flex items-center gap-6\" data-kid=\"4\">\n      <a href=\"#\" class=\"font-serif-lora text-3xl font-700 tracking-tight shrink-0\" style=\"color:#4B3621;\" data-kid=\"5\">Dimar</a>\n      <div class=\"flex-1 max-w-xl mx-auto\" data-kid=\"6\">\n        <div class=\"flex items-center gap-3 px-5 h-12 rounded-full bg-white/70 border border-[#4B362114]\" style=\"box-shadow:0 1px 2px rgba(75,54,33,.04);\" data-kid=\"7\">\n          <i class=\"ti ti-search text-lg\" style=\"color:#A45A52;\" data-kid=\"8\"></i>\n          <input type=\"text\" placeholder=\"Buscar productos...\" class=\"flex-1 bg-transparent outline-none text-sm placeholder:text-[#4B362180]\" style=\"color:#4B3621;\" data-kid=\"9\">\n        </div>\n      </div>\n      <nav class=\"flex items-center gap-5 shrink-0\" data-kid=\"10\">\n        <a href=\"#\" class=\"hidden lg:inline text-sm font-500 link-underline\" style=\"color:#4B3621;\" data-kid=\"11\">Categorías</a>\n        <button class=\"relative\" aria-label=\"Carrito\" data-kid=\"12\">\n          <i class=\"ti ti-shopping-cart text-2xl\" style=\"color:#4B3621;\" data-kid=\"13\"></i>\n          <span class=\"absolute -top-2 -right-2 w-5 h-5 rounded-full text-[10px] font-700 text-white flex items-center justify-center\" style=\"background-color:#A45A52;\" data-kid=\"14\">2</span>\n        </button>\n        <button aria-label=\"Favoritos\" data-kid=\"15\"><i class=\"ti ti-heart text-2xl\" style=\"color:#4B3621;\" data-kid=\"16\"></i></button>\n        <span class=\"w-9 h-9 rounded-full flex items-center justify-center text-white font-600 text-sm font-serif-lora\" style=\"background-color:#85B09A;\" data-kid=\"17\">D</span>\n      </nav>\n    </div>\n  </header>\n\n  \n  <section class=\"relative overflow-hidden\" style=\"height:85vh; min-height:620px; background-color:#F4F0EC;\" data-kid=\"18\">\n    \n    <img src=\"https://images.pexels.com/photos/15645402/pexels-photo-15645402.jpeg?auto=compress&cs=tinysrgb&w=1400&q=80\" alt=\"Vista aérea de paisaje andino peruano\" decoding=\"async\" loading=\"lazy\" class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"19\">\n    \n    <svg class=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" aria-hidden=\"true\" data-kid=\"20\">\n      <path d=\"M0,0 L64,0 C58,18 70,34 60,50 C53,62 66,78 55,90 C50,96 56,100 48,100 L0,100 Z\" fill=\"#F4F0EC\" data-kid=\"21\"></path>\n    </svg>\n    \n    <div class=\"relative z-10 max-w-[1240px] mx-auto px-8 h-full flex items-center\" data-kid=\"22\">\n      <div class=\"max-w-xl reveal\" data-kid=\"23\">\n        <p class=\"text-xs font-600 tracking-[0.25em] uppercase mb-5\" style=\"color:#A45A52;\" data-kid=\"24\">Tienda online · Lima, Perú</p>\n        <h1 class=\"font-serif-lora font-600\" style=\"color:#4B3621; font-size:clamp(2.6rem,5.2vw,4.6rem); line-height:1.04; letter-spacing:-0.01em;\" data-kid=\"25\">Compra inteligente,<br data-kid=\"26\">vive mejor.</h1>\n        <p class=\"mt-6 text-base leading-relaxed max-w-md\" style=\"color:#4B3621CC;\" data-kid=\"27\">Productos cuidadosamente seleccionados y entregados en tu puerta. Calidad sin compromiso, desde el primer clic.</p>\n        <div class=\"mt-9 flex items-center gap-7\" data-kid=\"28\">\n          <a href=\"#\" class=\"inline-flex items-center gap-2 px-8 py-4 rounded-full text-white text-sm font-600 tracking-wide\" style=\"background-color:#A45A52; box-shadow:0 10px 24px rgba(164,90,82,.32);\" data-kid=\"29\">\n            Explorar catálogo <i class=\"ti ti-arrow-right text-base\" data-kid=\"30\"></i>\n          </a>\n          <a href=\"#\" class=\"text-sm font-600 link-underline inline-flex items-center gap-2\" style=\"color:#85B09A;\" data-kid=\"31\">Ver novedades <i class=\"ti ti-sparkles text-base\" data-kid=\"32\"></i></a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative max-w-[1240px] mx-auto px-8 py-24\" data-kid=\"33\">\n    <svg class=\"absolute left-0 top-0 w-full h-full pointer-events-none\" viewBox=\"0 0 1200 360\" fill=\"none\" preserveAspectRatio=\"none\" aria-hidden=\"true\" data-kid=\"34\">\n      <path id=\"constellation-path\" d=\"M60,300 C260,300 260,90 480,90 C700,90 700,300 920,300 C1060,300 1100,150 1160,120\" stroke=\"#A45A5255\" stroke-width=\"2\" stroke-dasharray=\"2 8\" stroke-linecap=\"round\" data-kid=\"35\"></path>\n    </svg>\n    <div class=\"relative grid grid-cols-1 md:grid-cols-4 gap-y-14 gap-x-6\" data-kid=\"36\">\n      <div class=\"reveal flex items-start gap-4 md:mt-44\" data-kid=\"37\">\n        <span class=\"mt-1 w-3.5 h-3.5 rounded-full shrink-0 ring-4 ring-[#A45A5222]\" style=\"background-color:#A45A52;\" data-kid=\"38\"></span>\n        <div data-kid=\"39\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"40\"><i class=\"ti ti-truck-delivery text-xl\" style=\"color:#A45A52;\" data-kid=\"41\"></i><p class=\"font-serif-lora text-lg font-600\" style=\"color:#4B3621;\" data-kid=\"42\">Envío gratis</p></div>\n          <p class=\"text-sm\" style=\"color:#4B362199;\" data-kid=\"43\">En pedidos +S/150</p>\n        </div>\n      </div>\n      <div class=\"reveal flex items-start gap-4 md:mt-4\" data-kid=\"44\">\n        <span class=\"mt-1 w-3.5 h-3.5 rounded-full shrink-0 ring-4 ring-[#A45A5222]\" style=\"background-color:#A45A52;\" data-kid=\"45\"></span>\n        <div data-kid=\"46\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"47\"><i class=\"ti ti-shield-check text-xl\" style=\"color:#A45A52;\" data-kid=\"48\"></i><p class=\"font-serif-lora text-lg font-600\" style=\"color:#4B3621;\" data-kid=\"49\">Compra segura</p></div>\n          <p class=\"text-sm\" style=\"color:#4B362199;\" data-kid=\"50\">Datos siempre protegidos</p>\n        </div>\n      </div>\n      <div class=\"reveal flex items-start gap-4 md:mt-44\" data-kid=\"51\">\n        <span class=\"mt-1 w-3.5 h-3.5 rounded-full shrink-0 ring-4 ring-[#A45A5222]\" style=\"background-color:#A45A52;\" data-kid=\"52\"></span>\n        <div data-kid=\"53\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"54\"><i class=\"ti ti-refresh text-xl\" style=\"color:#A45A52;\" data-kid=\"55\"></i><p class=\"font-serif-lora text-lg font-600\" style=\"color:#4B3621;\" data-kid=\"56\">30 días</p></div>\n          <p class=\"text-sm\" style=\"color:#4B362199;\" data-kid=\"57\">Cambios y devoluciones</p>\n        </div>\n      </div>\n      <div class=\"reveal flex items-start gap-4\" data-kid=\"58\">\n        <span class=\"mt-1 w-3.5 h-3.5 rounded-full shrink-0 ring-4 ring-[#A45A5222]\" style=\"background-color:#A45A52;\" data-kid=\"59\"></span>\n        <div data-kid=\"60\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"61\"><i class=\"ti ti-headphones text-xl\" style=\"color:#A45A52;\" data-kid=\"62\"></i><p class=\"font-serif-lora text-lg font-600\" style=\"color:#4B3621;\" data-kid=\"63\">Soporte 24/7</p></div>\n          <p class=\"text-sm\" style=\"color:#4B362199;\" data-kid=\"64\">Siempre disponible</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-[1240px] mx-auto px-8 pb-24\" data-kid=\"65\">\n    <div class=\"reveal mb-14 flex items-end justify-between flex-wrap gap-4\" data-kid=\"66\">\n      <div data-kid=\"67\">\n        <p class=\"text-xs font-600 tracking-[0.25em] uppercase mb-3\" style=\"color:#A45A52;\" data-kid=\"68\">Navegar por</p>\n        <h2 class=\"font-serif-lora font-600\" style=\"color:#4B3621; font-size:clamp(2rem,3.5vw,3rem); line-height:1;\" data-kid=\"69\">Categorías</h2>\n      </div>\n      <a href=\"#\" class=\"text-sm font-600 link-underline inline-flex items-center gap-2\" style=\"color:#A45A52;\" data-kid=\"70\">Ver todo <i class=\"ti ti-arrow-right\" data-kid=\"71\"></i></a>\n    </div>\n    <div class=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 items-start\" data-kid=\"72\">\n      <a href=\"#\" class=\"cat-blob group block relative aspect-[3/4] overflow-hidden md:mt-0 rounded-[60%_40%_30%_70%/60%_30%_70%_40%]\" data-kid=\"73\">\n        <img src=\"https://images.unsplash.com/photo-1552312097-8ef75595e2a2?crop=entropy&cs=srgb&fm=jpg&q=85&w=600\" alt=\"Electrónica\" decoding=\"async\" loading=\"lazy\" class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"74\">\n        <span class=\"absolute inset-0\" style=\"background:linear-gradient(180deg,rgba(75,54,33,.05),rgba(75,54,33,.5));\" data-kid=\"75\"></span>\n        <span class=\"absolute inset-0 flex items-center justify-center font-serif-lora text-white text-xl font-600 drop-shadow\" data-kid=\"76\">Electrónica</span>\n      </a>\n     