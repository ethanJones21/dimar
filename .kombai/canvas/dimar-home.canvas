pan class=\"absolute inset-0 flex items-center justify-center font-serif-lora text-white text-xl font-600 drop-shadow\" data-kid=\"88\">Deportes</span>\n      </a>\n      <a href=\"#\" class=\"cat-blob group block relative aspect-[3/4] overflow-hidden md:mt-16 rounded-[60%_40%_50%_50%/40%_60%_40%_60%]\" data-kid=\"89\">\n        <img src=\"https://images.pexels.com/photos/20087170/pexels-photo-20087170.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Libros\" decoding=\"async\" loading=\"lazy\" class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"90\">\n        <span class=\"absolute inset-0\" style=\"background:linear-gradient(180deg,rgba(75,54,33,.05),rgba(75,54,33,.5));\" data-kid=\"91\"></span>\n        <span class=\"absolute inset-0 flex items-center justify-center font-serif-lora text-white text-xl font-600 drop-shadow\" data-kid=\"92\">Libros</span>\n      </a>\n      <a href=\"#\" class=\"cat-blob group block relative aspect-[3/4] overflow-hidden md:mt-2 rounded-[45%_55%_35%_65%/55%_45%_55%_45%]\" data-kid=\"93\">\n        <img src=\"https://images.pexels.com/photos/7233327/pexels-photo-7233327.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Belleza\" decoding=\"async\" loading=\"lazy\" class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"94\">\n        <span class=\"absolute inset-0\" style=\"background:linear-gradient(180deg,rgba(75,54,33,.05),rgba(75,54,33,.5));\" data-kid=\"95\"></span>\n        <span class=\"absolute inset-0 flex items-center justify-center font-serif-lora text-white text-xl font-600 drop-shadow\" data-kid=\"96\">Belleza</span>\n      </a>\n    </div>\n  </section>\n\n  \n  <section class=\"relative overflow-hidden py-28\" style=\"background-color:#EFEAE3;\" data-kid=\"97\">\n    <span class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 font-serif-lora font-700 whitespace-nowrap select-none pointer-events-none\" style=\"color:#A45A5212; font-size:clamp(8rem,22vw,20rem); line-height:1;\" data-kid=\"98\">CALIDAD</span>\n    <div class=\"relative max-w-[1240px] mx-auto px-8 grid lg:grid-cols-12 gap-12 items-center\" data-kid=\"99\">\n      <div class=\"reveal lg:col-span-6 lg:col-start-1\" data-kid=\"100\">\n        <p class=\"text-xs font-600 tracking-[0.25em] uppercase mb-5\" style=\"color:#A45A52;\" data-kid=\"101\">Nuestra misión</p>\n        <p class=\"font-serif-lora\" style=\"color:#4B3621; font-size:clamp(1.5rem,2.6vw,2.1rem); line-height:1.45; max-width:60ch;\" data-kid=\"102\">En Dimar creemos que acceder a buenos productos no debería ser complicado. Cuidamos cada paso, desde la selección hasta la entrega en tu puerta.</p>\n        <a href=\"#\" class=\"mt-8 inline-flex items-center gap-2 text-sm font-600 link-underline\" style=\"color:#A45A52;\" data-kid=\"103\">Conoce nuestra historia <i class=\"ti ti-arrow-right\" data-kid=\"104\"></i></a>\n      </div>\n      <div class=\"reveal lg:col-span-5 lg:col-start-8 lg:translate-y-6\" data-kid=\"105\">\n        <img src=\"https://images.unsplash.com/photo-1722963295936-03ea25f1d4d2?crop=entropy&cs=srgb&fm=jpg&q=85&w=700\" alt=\"Artesano trabajando\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-[440px] object-cover rounded-[42%_58%_60%_40%/45%_42%_58%_55%]\" style=\"box-shadow:0 24px 60px rgba(75,54,33,.18);\" data-kid=\"106\">\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative max-w-[1100px] mx-auto px-8 py-28\" data-kid=\"107\">\n    <div class=\"reveal text-center mb-20\" data-kid=\"108\">\n      <p class=\"text-xs font-600 tracking-[0.25em] uppercase mb-3\" style=\"color:#A45A52;\" data-kid=\"109\">Selección especial</p>\n      <h2 class=\"font-serif-lora font-600\" style=\"color:#4B3621; font-size:clamp(2rem,3.5vw,3rem); line-height:1;\" data-kid=\"110\">Destacados</h2>\n    </div>\n    \n    <div class=\"absolute left-1/2 top-48 bottom-32 w-px -translate-x-1/2 hidden md:block\" style=\"background:linear-gradient(#A45A5240,#A45A5210);\" data-kid=\"111\"></div>\n\n    