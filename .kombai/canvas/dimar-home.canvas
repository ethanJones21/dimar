187\"></i>\n          <p class=\"font-sans font-semibold text-[18px] leading-snug relative z-10\" data-kid=\"188\">Cobertura en Lima Metropolitana</p>\n          <div class=\"absolute -bottom-8 -right-8 w-32 h-32 rounded-full border-2 border-white/20\" data-kid=\"189\"></div>\n          <div class=\"absolute -bottom-4 -right-4 w-20 h-20 rounded-full border-2 border-white/20\" data-kid=\"190\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative\" data-kid=\"191\">\n    <div class=\"absolute inset-x-0 top-0 h-1/2 bg-[#FAFAF9]\" data-kid=\"192\"></div>\n    <div class=\"absolute inset-x-0 bottom-0 h-1/2 bg-[#36454F]\" data-kid=\"193\"></div>\n    <div class=\"relative max-w-[1000px] mx-auto px-8 py-20\" data-kid=\"194\">\n      <div class=\"reveal text-center mb-10\" data-kid=\"195\">\n        <p class=\"text-[11px] font-semibold tracking-[0.3em] uppercase text-[#7BAFD4] mb-3\" data-kid=\"196\">Experiencia Dimar</p>\n        <h2 class=\"font-serif font-bold text-[#36454F] tracking-[-0.02em]\" style=\"font-size:clamp(2rem,3.8vw,3.2rem)\" data-kid=\"197\">Compra inteligente, vive mejor.</h2>\n      </div>\n      <div class=\"reveal relative rounded-2xl overflow-hidden shadow-[0_30px_80px_rgba(0,0,0,0.3)] aspect-video group cursor-pointer\" id=\"showcaseWrap\" data-kid=\"198\">\n        <video id=\"showcaseVideo\" src=\"https://videos.pexels.com/video-files/4565886/4565886-hd_1280_720_24fps.mp4\" poster=\"https://images.pexels.com/videos/4565886/pexels-photo-4565886.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover\" data-kid=\"199\"></video>\n        <button id=\"showcaseBtn\" class=\"absolute inset-0 flex items-center justify-center bg-black/20\" data-kid=\"200\">\n          <span class=\"w-20 h-20 rounded-full bg-white/25 backdrop-blur-md border border-white/40 flex items-center justify-center text-white text-[30px]\" data-kid=\"201\"><i class=\"ti ti-player-play-filled\" data-kid=\"202\"></i></span>\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[#FAFAF9] py-28\" data-kid=\"203\">\n    <div class=\"max-w-[1240px] mx-auto px-8 min-h-[420px] flex flex-col reveal\" data-kid=\"204\">\n      <h2 class=\"font-serif font-bold text-[#36454F] tracking-[-0.03em] leading-none\" style=\"font-size:clamp(5rem,16vw,15rem)\" data-kid=\"205\">Únete</h2>\n      <div class=\"mt-auto self-end w-full max-w-md text-right\" data-kid=\"206\">\n        <p class=\"text-[11px] font-semibold tracking-[0.28em] uppercase text-[#7BAFD4] mb-4\" data-kid=\"207\">No te pierdas nada</p>\n        <div class=\"flex items-end gap-4 border-b-2 border-[#36454F] pb-2\" data-kid=\"208\">\n          <input type=\"email\" placeholder=\"tu@correo.com\" class=\"flex-1 bg-transparent outline-none text-[18px] text-[#36454F] placeholder:text-[#9aa3a9] text-left\" data-kid=\"209\">\n          <button class=\"text-[14px] font-semibold text-[#36454F] whitespace-nowrap ulink\" data-kid=\"210\">Suscribirse</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[#36454F] text-white/90\" data-kid=\"211\">\n    <div class=\"max-w-[1240px] mx-auto px-8 pt-16 pb-10\" data-kid=\"212\">\n      <div class=\"flex flex-col md:flex-row md:items-end md:justify-between gap-6 pb-10 border-b border-white/12\" data-kid=\"213\">\n        <div data-kid=\"214\">\n          <p class=\"font-serif font-bold text-[52px] leading-none tracking-[-0.02em]\" data-kid=\"215\">Dimar</p>\n        </div>\n        <p class=\"text-white/55 text-[14px] max-w-xs leading-relaxed\" data-kid=\"216\">Tu tienda online de confianza. Lima, Perú.</p>\n      </div>\n\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-10 py-12\" data-kid=\"217\">\n        <div data-kid=\"218\">\n          <p class=\"text-[11px] font-semibold tracking-[0.22em] uppercase text-white/45 mb-5\" data-kid=\"219\">Tienda</p>\n          <ul class=\"space-y-3 text-[14px] text-white/70\" data-kid=\"220\">\n            <li data-kid=\"221\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"222\">Todos los productos</a></li>\n            <li data-kid=\"223\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"224\">Categorías</a></li>\n            <li data-kid=\"225\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"226\">Ofertas</a></li>\n            <li data-kid=\"227\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"228\">Novedades</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"229\">\n          <p class=\"text-[11px] font-semibold tracking-[0.22em] uppercase text-white/45 mb-5\" data-kid=\"230\">Mi cuenta</p>\n          <ul class=\"space-y-3 text-[14px] text-white/70\" data-kid=\"231\">\n            <li data-kid=\"232\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"233\">Mis pedidos</a></li>\n            <li data-kid=\"234\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"235\">Iniciar sesión</a></li>\n            <li data-kid=\"236\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"237\">Registrarse</a></li>\n            <li data-kid=\"238\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"239\">Mi carrito</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"240\">\n          <p class=\"text-[11px] font-semibold tracking-[0.22em] uppercase text-white/45 mb-5\" data-kid=\"241\">Ayuda</p>\n          <ul class=\"space-y-3 text-[14px] text-white/70\" data-kid=\"242\">\n            <li data-kid=\"243\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"244\">Preguntas frecuentes</a></li>\n            <li data-kid=\"245\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"246\">Envíos y devoluciones</a></li>\n            <li data-kid=\"247\"><a href=\"#\" class=\"hover:tex