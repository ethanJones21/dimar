"><a href=\"#\" class=\"hover:text-[#85B09A]\" data-kid=\"282\">Privacidad</a></li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"mt-14 pt-8 flex flex-col sm:flex-row items-center justify-between gap-5\" style=\"border-top:1px solid rgba(244,240,236,.12);\" data-kid=\"283\">\n        <div class=\"flex flex-wrap items-center gap-2\" data-kid=\"284\">\n          <span class=\"text-[11px] font-600 mr-1 text-[#F4F0EC]/50\" data-kid=\"285\">Pagos seguros:</span>\n          <span class=\"px-2.5 py-1 rounded-md text-[11px] font-700 text-[#F4F0EC]/80\" style=\"background-color:#F4F0EC1a;\" data-kid=\"286\">VISA</span>\n          <span class=\"px-2.5 py-1 rounded-md text-[11px] font-700 text-[#F4F0EC]/80\" style=\"background-color:#F4F0EC1a;\" data-kid=\"287\">MASTERCARD</span>\n          <span class=\"px-2.5 py-1 rounded-md text-[11px] font-700 text-[#F4F0EC]/80\" style=\"background-color:#F4F0EC1a;\" data-kid=\"288\">YAPE</span>\n          <span class=\"px-2.5 py-1 rounded-md text-[11px] font-700 text-[#F4F0EC]/80\" style=\"background-color:#F4F0EC1a;\" data-kid=\"289\">MERCADOPAGO</span>\n        </div>\n        <p class=\"text-[11px] text-[#F4F0EC]/45 tracking-wide\" data-kid=\"290\">© 2026 DIMAR STORE — Todos los derechos reservados</p>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script type=\"module\" data-kid=\"291\">\n  import { animate, onScroll, utils } from 'https://esm.sh/animejs@4';\n\n  // Fade-up reveal once on enter\n  const reveals = document.querySelectorAll('.reveal');\n  const io = new IntersectionObserver((entries) => {\n    entries.forEach((entry) => {\n      if (entry.isIntersecting) {\n        animate(entry.target, {\n          opacity: [0, 1],\n          translateY: [42, 0],\n          duration: 850,\n          ease: 'out(3)',\n        });\n        io.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });\n  reveals.forEach((el) => io.observe(el));\n\n  // Ambient slow breathe on category blobs\n  utils.$('.cat-blob').forEach((el, i) => {\n    animate(el, {\n      scale: [1, 1.018],\n      duration: 3600 + i * 220,\n      alternate: true,\n      loop: true,\n      ease: 'inOut(2)',\n    });\n  });\n\n  // Scroll-driven path draw on the constellation curve\n  const cpath = document.querySelector('#constellation-path');\n  if (cpath) {\n    const len = cpath.getTotalLength();\n    cpath.style.strokeDasharray = len;\n    cpath.style.strokeDashoffset = len;\n    animate(cpath, {\n      strokeDashoffset: [len, 0],\n      ease: 'linear',\n      autoplay: onScroll({ target: cpath.closest('section'), enter: 'bottom top', leave: 'top bottom', sync: 0.6 }),\n    });\n  }\n</script>",
